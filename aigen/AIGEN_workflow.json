    {
      "parameters": {
        "jsCode": "const log = $('Webhook').first().json.body.rawLog;\n\n// Define high-priority failure signals\nconst signals = [\n  \"FAIL\",                // Standard Jest failure\n  \"AssertionError\",      // Logic mismatch\n  \"ECONNREFUSED\",        // Database/Network issue\n  \"ReferenceError\",      // Code typo/missing variable\n  \"Test Suites: 0 total\" // Something went catastrophically wrong with the setup\n];\n\nconst needsAI = signals.some(signal => log.includes(signal));\n\nreturn {\n  needsAI: needsAI,\n  reason: needsAI ? \"Failure detected in log\" : \"All tests passed or log empty\"\n};"
      },
