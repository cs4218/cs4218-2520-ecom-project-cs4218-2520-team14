    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\n\nconst sources = items.filter(x => x.kind === 'source');\nconst tests = items.filter(x => x.kind === 'test');\n\nfunction isIntegrationTest(path) {\n  const p = path.toLowerCase();\n  return p.includes('integration') || p.includes('e2e');\n}\n\nfunction isUnitTest(path) {\n  const p = path.toLowerCase();\n  return p.includes('.test.') && !isIntegrationTest(p);\n}\n\nconst output = sources.map(source => {\n  const sourceKey = source.name.split('.')[0];\n\n  const relatedTests = tests.filter(test => {\n    const testKey = test.name.split('.')[0];\n    return testKey === sourceKey;\n  });\n\n  const unitTests = relatedTests.filter(test => isUnitTest(test.path));\n  const integrationTests = relatedTests.filter(test => isIntegrationTest(test.path));\n\n  return {\n    json: {\n      sourcePath: source.path,\n      sourceName: source.name,\n      unitTests: unitTests.map(t => t.path),\n      integrationTests: integrationTests.map(t => t.path),\n      hasUnit: unitTests.length > 0,\n      hasIntegration: integrationTests.length > 0\n    }\n  };\n});\n\nreturn output;"
      },
